# =============================================================================
# Graph RAG Assistant - Environment Configuration Example
# =============================================================================
# Copy this file to .env and replace placeholder values with your real secrets.
# .env must NEVER be committed to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# OpenAI / LLM Providers
# -----------------------------------------------------------------------------
# Required. Use a real OpenAI key in production. Use OPENAI_API_KEY=sk-test
# for a local demo mode that returns static responses without calling OpenAI.
OPENAI_API_KEY=sk-...

# Main model used for the final answer and relation extraction.
OPENAI_MODEL=gpt-5.4

# Models used by the agentic router and Cypher generation.
ROUTER_MODEL=gpt-5.4-mini
CYPHER_MODEL=gpt-5.4-mini

# Model used to generate per-chunk situational context (contextual retrieval).
CONTEXTUAL_RETRIEVAL_MODEL=gpt-5.4-nano

# Model used to summarize graph communities for overview questions.
COMMUNITY_SUMMARY_MODEL=gpt-5.4-nano

# Embedding model and dimensions. Must match the vector store collection.
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIMENSIONS=3072
EMBEDDING_BATCH_SIZE=96

# Sampling temperature for LLM completions.
LLM_TEMPERATURE=0.1

# -----------------------------------------------------------------------------
# Document Parsing
# -----------------------------------------------------------------------------
# Enable OCR fallback when extracted text is below MIN_TEXT_CHARS_FOR_OCR.
ENABLE_OCR=false
MIN_TEXT_CHARS_FOR_OCR=100

# -----------------------------------------------------------------------------
# Vector Store (Qdrant)
# -----------------------------------------------------------------------------
QDRANT_ENABLE_NATIVE_SPARSE=true
QDRANT_DENSE_VECTOR_NAME=dense
QDRANT_SPARSE_VECTOR_NAME=text_sparse
QDRANT_UPSERT_BATCH_SIZE=500

# -----------------------------------------------------------------------------
# Retrieval & Reranking
# -----------------------------------------------------------------------------
RETRIEVAL_OVERSAMPLING_FACTOR=3
RETRIEVAL_LEXICAL_WEIGHT=0.15
RETRIEVAL_SCORE_THRESHOLD=0.25
ENABLE_RERANKER=true
RERANKER_MODEL=cross-encoder/mmarco-mMiniLMv2-L12-H384-v1

# -----------------------------------------------------------------------------
# Contextual Retrieval
# -----------------------------------------------------------------------------
ENABLE_RICH_CONTEXTUAL_RETRIEVAL=true
CONTEXTUAL_RETRIEVAL_MAX_DOC_CHARS=12000
CONTEXTUAL_RETRIEVAL_CONCURRENCY=5

# -----------------------------------------------------------------------------
# Graph Extraction (GLiNER)
# -----------------------------------------------------------------------------
ENABLE_GLINER=true
GLINER_MODEL=gliner-community/gliner_small-v2.5
GLINER_LABELS=Persona,Organizzazione,Luogo,Prodotto,Concetto,Regola,Requisito,Rischio,Data,Numero,Sistema
GLINER_THRESHOLD=0.5

# -----------------------------------------------------------------------------
# Agent / Critic / Community Detection
# -----------------------------------------------------------------------------
AGENT_MAX_ITERATIONS=3
AGENT_CYPHER_MAX_RETRIES=1
AGENT_MAX_GRAPH_FACTS=20
AGENT_MAX_COMMUNITY_SUMMARIES=5
COMMUNITY_DETECTION_ALGORITHM=louvain
COMMUNITY_DETECTION_RESOLUTION=1.0
COMMUNITY_SUMMARY_MAX_ENTITIES=50

# -----------------------------------------------------------------------------
# Backend / Authentication
# -----------------------------------------------------------------------------
# Long random string used to sign JWT tokens. Generate with:
#   openssl rand -hex 32
SECRET_KEY=change-me-to-a-256-bit-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Auto-create SQL tables on startup. Set to false in production (use Alembic).
AUTO_CREATE_TABLES=true

# -----------------------------------------------------------------------------
# Postgres Database
# -----------------------------------------------------------------------------
# These values are used by docker-compose to configure the Postgres container.
# The backend connection string is built from them in docker-compose.yml.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=graph_rag_assistant

# -----------------------------------------------------------------------------
# Neo4j
# -----------------------------------------------------------------------------
NEO4J_PASSWORD=change-me

# -----------------------------------------------------------------------------
# MinIO Object Storage
# -----------------------------------------------------------------------------
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# -----------------------------------------------------------------------------
# Redis / Celery
# -----------------------------------------------------------------------------
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# -----------------------------------------------------------------------------
# MCP Server
# -----------------------------------------------------------------------------
# Secret shared between the MCP server and clients calling the MCP endpoint.
MCP_API_KEY=change-me

# -----------------------------------------------------------------------------
# LibreChat / Meilisearch
# -----------------------------------------------------------------------------
# Shared API key used by LibreChat to call the backend.
LIBRECHAT_BACKEND_API_KEY=change-me

# Meilisearch master key used by LibreChat for its search index.
MEILI_MASTER_KEY=change-me
